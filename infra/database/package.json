{
  "name": "infra-supabase",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "start": "supabase start",
    "stop": "supabase stop",
    "migrate": "supabase migration up",
    "reset": "supabase db reset",
    "deploy-function": "supabase functions deploy",
    "seed": "for file in ./seeds/*.sql; do psql \"$PROD_DB_URL\" -v ON_ERROR_STOP=1 -f \"$file\"; done",
    "deploy": "supabase db push --db-url \"$PROD_DB_URL\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1"
  }
}
